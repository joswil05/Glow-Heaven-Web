{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Un producto de perfume o accesorio en el catálogo de Glow Heaven",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID unico del producto"
        },
        "nombre": {
          "type": "string",
          "description": "Nombre de la fragancia o del bolso"
        },
        "marca": {
          "type": "string",
          "description": "Marca fabricante"
        },
        "genero": {
          "type": "string",
          "description": "Genero al que esta dirigido"
        },
        "categoria": {
          "type": "string",
          "description": "Categoria de producto: perfume o accesorio"
        },
        "notas": {
          "type": "string",
          "description": "Notas olfativas para perfumes, representadas como texto o lista libre"
        },
        "color": {
          "type": "string",
          "description": "Color para accesorios"
        },
        "material": {
          "type": "string",
          "description": "Material para accesorios"
        },
        "precio": {
          "type": "number",
          "description": "Precio unitario del producto en USD"
        },
        "stock": {
          "type": "number",
          "description": "Cantidad disponible en inventario"
        },
        "imagenUrl": {
          "type": "string",
          "description": "URL de la imagen del producto"
        },
        "activo": {
          "type": "boolean",
          "description": "Indica si el producto esta activo"
        },
        "descripcion": {
          "type": "string",
          "description": "Descripcion detallada del producto"
        }
      },
      "required": [
        "id",
        "nombre",
        "marca",
        "genero",
        "categoria",
        "precio",
        "stock",
        "imagenUrl",
        "activo"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Un pedido de compra en Glow Heaven",
      "type": "object",
      "properties": {
        "id_pedido": {
          "type": "string",
          "description": "ID de transaccion de la base de datos o alias"
        },
        "fecha": {
          "type": "string",
          "description": "Fecha y hora de creacion de la preventa"
        },
        "cliente": {
          "type": "string",
          "description": "Informacion estructurada del cliente"
        },
        "items": {
          "type": "string",
          "description": "Articulos incluidos en la compra"
        },
        "total": {
          "type": "number",
          "description": "Monto total de la compra"
        },
        "metodo_pago": {
          "type": "string",
          "description": "Metodo de pago elegido"
        },
        "estado": {
          "type": "string",
          "description": "Estado de procesamiento del pedido"
        },
        "expiraEn": {
          "type": "string",
          "description": "Vigencia de reserva"
        }
      },
      "required": [
        "id_pedido",
        "fecha",
        "cliente",
        "items",
        "total",
        "metodo_pago",
        "estado"
      ]
    }
  },
  "firestore": {
    "productos": {
      "schema": "Product",
      "description": "Catalogo de productos en tiempo real"
    },
    "pedidos": {
      "schema": "Order",
      "description": "Ventas y reservas realizadas por los usuarios"
    }
  }
}
