rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Collection 'productos'
    // - Anyone can read/list products to browse the catalog.
    // - Writes are permitted for seeding (creates/updates) and transactions (stock increments/decrements).
    match /productos/{productId} {
      allow read, list: if true;
      
      allow create: if isValidId(productId)
        && request.resource.data.id == productId
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0
        && request.resource.data.nombre.size() <= 100
        && request.resource.data.marca is string
        && request.resource.data.marca.size() > 0
        && request.resource.data.marca.size() <= 100
        && request.resource.data.categoria is string
        && request.resource.data.precio is number
        && request.resource.data.precio >= 0
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;

      allow update: if isValidId(productId) && (
        // Action 1: Full/Data sync update (ERP catalog editor, inventory sync)
        (
          request.resource.data.id == productId
          && request.resource.data.nombre is string
          && request.resource.data.marca is string
          && request.resource.data.precio is number
          && request.resource.data.stock is number
          && request.resource.data.stock >= 0
        ) ||
        // Action 2: Stock and commitment update (web purchase)
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'stock_comprometido', 'stock_disponible'])
          && request.resource.data.stock is number
          && request.resource.data.stock >= 0
          && request.resource.data.stock_disponible is number
          && request.resource.data.stock_disponible >= 0
          && request.resource.data.stock_comprometido is number
          && request.resource.data.stock_comprometido >= 0
        ) ||
        // Action 3: Catalog metadata update (visibility, images, descriptions)
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['activo', 'imagenUrl', 'descripcion', 'genero', 'notas', 'precio'])
        ) ||
        // Action 4: ERP inventory batch injection (lotes, stock_disponible, stock_comprometido, stock)
        (
          request.resource.data.stock is number
          && request.resource.data.stock >= 0
        )
      );

      // Allow product deletion from ERP management
      allow delete: if isValidId(productId);
    }

    // 3. Collection 'pedidos'
    // - Guests can create (write) a new order.
    // - All reads, updates, and deletes are disabled (protects client PII from other users).
    match /pedidos/{orderId} {
      allow create: if isValidId(orderId) 
        && request.resource.data.id_orden == orderId
        && request.resource.data.cliente.nombre is string
        && request.resource.data.cliente.nombre.size() > 0
        && request.resource.data.cliente.nombre.size() <= 100
        && request.resource.data.cliente.telefono is string
        && request.resource.data.cliente.telefono.size() >= 7
        && request.resource.data.cliente.telefono.size() <= 20
        && request.resource.data.envio.direccion is string
        && request.resource.data.envio.direccion.size() > 0
        && request.resource.data.envio.direccion.size() <= 300
        && request.resource.data.envio.canal in ['web_whatsapp', 'mostrador_fisico', 'whatsapp', 'instagram']
        && request.resource.data.envio.banco_destino in ['banpro', 'lafise', 'bac']
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.total_cs is number
        && request.resource.data.total_cs > 0
        && request.resource.data.estado in ['pendiente_pago', 'stock_comprometido', 'listo_despacho', 'en_camino', 'entregado', 'cancelado'];
        
      allow read: if true;
      allow update: if isValidId(orderId);
      allow delete: if false;
    }

    // 4. Collection 'inventario_lotes'
    match /inventario_lotes/{batchId} {
      allow read, write: if true;
    }

    // 5. Collection 'transacciones_financieras'
    match /transacciones_financieras/{expenseId} {
      allow read, write: if true;
    }

    // 6. Collection 'configuracion'
    match /configuracion/{configId} {
      allow read, write: if true;
    }
  }
}
